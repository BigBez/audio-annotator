          "id": "2d9f624b-3beb-492f-aa3b-441f716285c3",
          "text": "It's pitiful, I can't believe",
          "startTime": 68.579841,
          "endTime": 70.575173
        },
        {
          "id": "ea074b6d-eff7-4568-991e-855e86f7b91a",
