        {
          "id": "6ace7dbe-ac1a-46cd-a52a-d74a30c8e53d",
          "text": "It's beautiful, it's bittersweet",
          "startTime": 10.326009,
          "endTime": 12.339115
        },
        {
          "id": "af84d0b6-d342-4c81-bb08-aa072a6c7fe2",
          "text": "You're like a broken home to me",
          "startTime": 12.339115,
          "endTime": 14.770204
        },
        {
          "id": "5a7a5205-8c4c-4b57-b7c1-9d45b6428296",
          "text": "I take a shot of memories",
          "startTime": 14.770204,
          "endTime": 17.200113
        },
        {
          "id": "174fce9c-dfb6-4f41-986a-ec0f4195b1b4",
          "text": "And black out like an empty street",
          "startTime": 17.200113,
          "endTime": 19.647573
        },
        {
          "id": "dcb86340-310b-444c-b438-cdc8f7247aa7",
          "text": "I fill my days with the way you walk",
          "startTime": 19.647573,
          "endTime": 22.081111
        },
        {
          "id": "e7e3b7f3-7d57-47a9-ac35-13aed635bb51",
          "text": "And fill my nights with broken dreams",
          "startTime": 22.081111,
          "endTime": 24.483287
        },
        {
          "id": "4461931a-6c97-4567-a708-071ea8fa73d0",
          "text": "I make up lies inside my head",
          "startTime": 24.483287,
          "endTime": 26.880929
        },
        {
          "id": "5f4cdb84-8079-458f-93d2-3ca118d633de",
          "text": "Like one day, you'll come back to me",
          "startTime": 26.880929,
          "endTime": null
        }
      ]
    },
