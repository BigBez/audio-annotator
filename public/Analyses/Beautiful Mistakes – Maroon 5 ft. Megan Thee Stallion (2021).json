        {
          "id": "2e7389ac-9c7a-4adb-aac1-189e97facaad",
          "text": "Yeah, bet you miss my love, all in your bed (Bed)",
          "startTime": 155.919521,
          "endTime": 158.812695
        },
        {
          "id": "390cbd52-e0f2-4c15-88e5-10341e9443e9",
          "text": "Now you're stressin' out, pullin' your hair (Hair)",
          "startTime": 158.812695,
          "endTime": 161.242808
        },
        {
          "id": "ddca7990-aae4-4df4-aa71-13344711fece",
          "text": "Smellin' your pillows and wishin' I was there (I was there)",
          "startTime": 161.242808,
          "endTime": 163.61918
        },
        {
          "id": "b1723ecb-eb4f-4361-919a-421423eae887",
          "text": "Slidin' down the shower wall, lookin' sad (Sad)",
          "startTime": 163.61918,
          "endTime": 165.943534
        },
        {
          "id": "87a83860-b2e3-44d1-b8b8-50558d7c040a",
          "text": "I know it's hard to let go, I'm the best (I'm the best)",
          "startTime": 165.943534,
          "endTime": 168.574486
        },
        {
          "id": "997ca469-eb35-42e4-82b6-71a7faea05ac",
          "text": "Best you ever had and best you gon' get (Gon' get)",
          "startTime": 168.574486,
          "endTime": 170.865756
        },
        {
          "id": "1b2693d3-a0f4-4578-a2cf-0a048127e0ed",
          "text": "And if we break up, I don't wanna be friends (Be friends)",
          "startTime": 170.865756,
          "endTime": null
        },
        {
          "id": "a9fc3e7b-14fa-4b46-aff3-4b0db7133ce8",
          "text": "You're toxic",
          "startTime": null,
          "endTime": null
        }
      ]
    },
