          "startTime": 70.575173,
          "endTime": 73.06778
        },
        {
          "id": "0b9b59db-cda8-4d7c-aa02-ecd17469ac8a",
          "text": "I take a break, I cut you off",
          "startTime": 73.06778,
          "endTime": 75.452905
        },
        {
          "id": "b19b000e-344b-405d-9150-854a8c704e99",
          "text": "To keep myself from lookin' soft",
          "startTime": 75.452905,
          "endTime": 77.881862
        },
        {
          "id": "766b9c90-a41e-4b3b-b517-6eba8a90b7e1",
