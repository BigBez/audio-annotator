          "startTime": 77.881862,
          "endTime": 80.272497
        },
        {
          "id": "efdcf90c-a046-4524-989d-d2f60ce8c94f",
          "text": "And still wake up with broken dreams",
          "startTime": 80.272497,
          "endTime": 82.731953
        },
        {
          "id": "d355b03f-cd01-46f5-b647-27457bf079b2",
